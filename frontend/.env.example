# Frontend prototype env
# Leave unset to call real backend (Eman Auth + Marc Assets) via Vite proxy.
# VITE_USE_MOCK=true
# VITE_API_BASE_URL=/api/v1

# LAN testing recommendation:
# Keep VITE_API_BASE_URL=/api/v1 when using the root runner.
# The Vite dev server proxies /api to the local Laravel backend, so phones on the same Wi-Fi can use:
#   http://YOUR_PC_IP:5173
#
# Only set a full backend URL if you intentionally want browser-to-backend direct calls:
# VITE_API_BASE_URL=http://YOUR_PC_IP:8000/api/v1
